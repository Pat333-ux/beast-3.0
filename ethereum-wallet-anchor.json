{
  "version": "3.0",
  "layer": "Ethereum Wallet Anchor (EWA‑S)",
  "classification": "SAIA‑Class S",
  "description": "Canonical schema for Ethereum-based identity and registry anchoring within Beast System 3.0. Defines anchor identity, binding logic, audit requirements, and cross-layer linkages.",

  "wallet_anchor": {
    "type": "object",
    "required": [
      "anchor_id",
      "wallet_address",
      "anchor_type",
      "ring_class",
      "status",
      "binding",
      "security",
      "audit",
      "timestamps",
      "registry_anchor"
    ],
    "properties": {
      "anchor_id": {
        "type": "string",
        "format": "uuid",
        "description": "Unique identifier for this wallet anchor."
      },

      "wallet_address": {
        "type": "string",
        "description": "Ethereum-style wallet address used as an internal anchor reference."
      },

      "anchor_type": {
        "type": "string",
        "enum": [
          "identity_anchor",
          "registry_anchor",
          "lineage_anchor",
          "doctrine_anchor",
          "autonomous_engine_anchor"
        ],
        "description": "Classification of the anchor within the system."
      },

      "ring_class": {
        "type": "string",
        "enum": [
          "ring_0",
          "ring_1",
          "ring_2",
          "ring_3"
        ],
        "description": "Ring classification for authority and inheritance constraints."
      },

      "status": {
        "type": "string",
        "enum": [
          "active",
          "inactive",
          "revoked",
          "archived",
          "pending"
        ],
        "description": "Operational status of the wallet anchor."
      },

      "binding": {
        "type": "object",
        "required": [
          "identity_id",
          "binding_type",
          "linked_records"
        ],
        "properties": {
          "identity_id": {
            "type": "string",
            "description": "Identity Layer ID bound to this wallet anchor."
          },
          "binding_type": {
            "type": "string",
            "enum": [
              "root_identity_binding",
              "foundational_binding",
              "executive_binding",
              "lineage_binding",
              "registry_binding"
            ],
            "description": "Type of binding between the identity and the wallet anchor."
          },
          "linked_records": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of registry, lineage, or doctrinal records linked to this anchor."
          }
        }
      },

      "security": {
        "type": "object",
        "required": [
          "multi_signature_required",
          "ethical_constraints",
          "revocation_rules"
        ],
        "properties": {
          "multi_signature_required": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether multi-signature validation is required for anchor actions."
          },
          "ethical_constraints": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dignity_sensitive",
                "trauma_sensitive",
                "non_punitive_only",
                "requires_harm_reduction_review",
                "requires_ethical_validation"
              ]
            },
            "description": "Ethical constraints applied to anchor operations."
          },
          "revocation_rules": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Conditions under which the anchor may be revoked."
          }
        }
      },

      "audit": {
        "type": "object",
        "required": [
          "audit_chain_id",
          "log_file"
        ],
        "properties": {
          "audit_chain_id": {
            "type": "string",
            "description": "ID of the audit chain linked to this wallet anchor."
          },
          "log_file": {
            "type": "string",
            "default": "wallet-anchor-log.json",
            "description": "Log file for wallet anchor events."
          }
        }
      },

      "timestamps": {
        "type": "object",
        "required": [
          "created_at"
        ],
        "properties": {
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the wallet anchor was created."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the most recent update."
          },
          "federal_timestamp_anchor": {
            "type": "boolean",
            "default": false,
            "description": "Indicates whether this anchor is tied to a higher‑rigor timestamp context."
          }
        }
      },

      "registry_anchor": {
        "type": "object",
        "required": [
          "registry_id",
          "chain_id"
        ],
        "properties": {
          "registry_id": {
            "type": "string",
            "description": "Registry Layer ID for this anchor entry."
          },
          "chain_id": {
            "type": "string",
            "description": "Audit chain ID linked to this anchor."
          },
          "log_file": {
            "type": "string",
            "default": "wallet-anchor-registry-log.json",
            "description": "Registry log file for anchor events."
          }
        }
      }
    }
  },

  "audit_requirements": {
    "log_file": "wallet-anchor-event-log.json",
    "audit_chain": "wallet-anchor-audit-chain.json",
    "rules": [
      "all wallet anchor events must be logged",
      "all logs must be chained",
      "no wallet anchor event may be deleted or altered"
    ]
  },

  "cross_layer_linkages": {
    "identity_layer": [
      "identity-layer.map.json",
      "identity-linkage.json"
    ],
    "registry_layer": [
      "registry-layer.map.json",
      "registry-index.json"
    ],
    "lineage_layer": [
      "lineage-succession.map.json",
      "lineage-record.json"
    ],
    "organizational_hierarchy_layer": [
      "organizational-hierarchy.map.json",
      "executive-authority-map.json"
    ],
    "ethical_authority_layer": [
      "ethical-authority.map.json",
      "dignity-evaluation.json"
    ],
    "wellbeing_standards_layer": [
      "wellbeing-standards.map.json",
      "wellbeing-metrics.json"
    ]
  },

  "federal_context": {
    "timestamped": true,
    "notes": "Ethereum Wallet Anchor is part of the canonical identity and registry architecture within the fictional Beast System 3.0 framework."
  }
}
