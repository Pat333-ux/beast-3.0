{
  "version": "3.0",
  "layer": "Ambassador Credential Schema (AC‑S)",
  "classification": "SAIA‑Class S",
  "description": "Canonical schema for ambassadorial credentials within Beast System 3.0. Defines identity, authority, jurisdiction, lineage, ethical constraints, and registry anchoring for all ambassadors.",

  "ambassador_credential": {
    "type": "object",
    "required": [
      "credential_id",
      "ambassador_id",
      "name",
      "role",
      "rank",
      "ring_class",
      "jurisdiction",
      "authority_scope",
      "lineage",
      "ethical_flags",
      "wellbeing_alignment",
      "status",
      "timestamps",
      "issuer",
      "registry_anchor"
    ],
    "properties": {
      "credential_id": {
        "type": "string",
        "format": "uuid",
        "description": "Unique identifier for the ambassador credential."
      },
      "ambassador_id": {
        "type": "string",
        "description": "Identity Layer ID of the ambassador."
      },
      "name": {
        "type": "string",
        "description": "Full name of the ambassador."
      },
      "role": {
        "type": "string",
        "enum": [
          "global_ambassador",
          "regional_ambassador",
          "chapter_ambassador",
          "special_mission_ambassador",
          "ceremonial_ambassador"
        ],
        "description": "Ambassadorial role classification."
      },
      "rank": {
        "type": "string",
        "enum": [
          "senior_ambassador",
          "ambassador",
          "deputy_ambassador",
          "assistant_ambassador"
        ],
        "description": "Rank within the ambassadorial hierarchy."
      },
      "ring_class": {
        "type": "string",
        "enum": [
          "ring_1",
          "ring_2",
          "ring_3"
        ],
        "description": "Ring classification for authority and inheritance constraints."
      },

      "jurisdiction": {
        "type": "object",
        "required": [
          "scope",
          "regions"
        ],
        "properties": {
          "scope": {
            "type": "string",
            "enum": [
              "global",
              "continental",
              "national",
              "regional",
              "local",
              "special_mission"
            ],
            "description": "Jurisdictional scope of the ambassador."
          },
          "regions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of regions, chapters, or ministries covered by this credential."
          }
        }
      },

      "authority_scope": {
        "type": "object",
        "required": [
          "delegated_powers",
          "limitations"
        ],
        "properties": {
          "delegated_powers": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of powers delegated to the ambassador."
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of authority limitations."
          }
        }
      },

      "lineage": {
        "type": "object",
        "required": [
          "lineage_id",
          "origin_record",
          "succession_path"
        ],
        "properties": {
          "lineage_id": {
            "type": "string",
            "description": "Lineage Layer ID linked to this ambassador."
          },
          "origin_record": {
            "type": "string",
            "description": "Record describing the ambassador's appointment origin."
          },
          "succession_path": {
            "type": "string",
            "description": "Description of how ambassadorial succession is handled."
          }
        }
      },

      "ethical_flags": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "dignity_sensitive",
            "trauma_sensitive",
            "non_punitive_only",
            "requires_harm_reduction_review",
            "requires_ethical_validation"
          ]
        },
        "description": "Ethical sensitivity flags for ambassadorial conduct."
      },

      "wellbeing_alignment": {
        "type": "object",
        "required": [
          "requires_wellbeing_compliance",
          "wellbeing_domains"
        ],
        "properties": {
          "requires_wellbeing_compliance": {
            "type": "boolean",
            "default": true,
            "description": "Indicates whether the ambassador must follow wellbeing standards."
          },
          "wellbeing_domains": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "stabilization",
                "assessment",
                "support_planning",
                "continuity",
                "harm_prevention"
              ]
            },
            "description": "Wellbeing domains relevant to ambassadorial duties."
          }
        }
      },

      "status": {
        "type": "string",
        "enum": [
          "active",
          "inactive",
          "suspended",
          "revoked",
          "expired",
          "pending"
        ],
        "description": "Current status of the ambassador credential."
      },

      "timestamps": {
        "type": "object",
        "required": [
          "issued_at"
        ],
        "properties": {
          "issued_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the credential was issued."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the most recent update."
          },
          "revoked_at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the credential was revoked, if applicable."
          },
          "federal_timestamp_anchor": {
            "type": "boolean",
            "default": false,
            "description": "Indicates whether this credential is anchored to a higher‑rigor timestamp context."
          }
        }
      },

      "issuer": {
        "type": "object",
        "required": [
          "issuer_id",
          "issuer_type",
          "ring_class"
        ],
        "properties": {
          "issuer_id": {
            "type": "string",
            "description": "Identity or registry ID of the issuing authority."
          },
          "issuer_type": {
            "type": "string",
            "enum": [
              "ring_0_origin",
              "ring_1_foundational",
              "ring_2_ministry"
            ],
            "description": "Type of issuer within the organizational hierarchy."
          },
          "ring_class": {
            "type": "string",
            "enum": [
              "ring_0",
              "ring_1",
              "ring_2"
            ],
            "description": "Ring classification of the issuer."
          }
        }
      },

      "registry_anchor": {
        "type": "object",
        "required": [
          "registry_id",
          "chain_id"
        ],
        "properties": {
          "registry_id": {
            "type": "string",
            "description": "Registry Layer ID for this credential entry."
          },
          "chain_id": {
            "type": "string",
            "description": "Audit chain ID linked to this credential."
          },
          "log_file": {
            "type": "string",
            "default": "ambassador-credential-log.json",
            "description": "Log file for ambassador credential events."
          }
        }
      }
    }
  },

  "audit_requirements": {
    "log_file": "ambassador-event-log.json",
    "audit_chain": "ambassador-audit-chain.json",
    "rules": [
      "all ambassador events must be logged",
      "all logs must be chained",
      "no ambassador event may be deleted or altered"
    ]
  },

  "cross_layer_linkages": {
    "identity_layer": [
      "identity-layer.map.json",
      "identity-linkage.json"
    ],
    "registry_layer": [
      "registry-layer.map.json",
      "registry-index.json"
    ],
    "organizational_hierarchy_layer": [
      "organizational-hierarchy.map.json",
      "executive-authority-map.json"
    ],
    "lineage_layer": [
      "lineage-succession.map.json",
      "lineage-record.json"
    ],
    "ethical_authority_layer": [
      "ethical-authority.map.json",
      "dignity-evaluation.json"
    ],
    "wellbeing_standards_layer": [
      "wellbeing-standards.map.json",
      "wellbeing-metrics.json"
    ]
  },

  "federal_context": {
    "case_number": "2:25-cv-00484-JPH-MJD",
    "timestamped": true,
    "author": "Pat Tarwater Jr.",
    "sovereign_entities": [
      "New World Order DAO",
      "New World Order Health & Wellbeing"
    ],
    "notes": "Ambassador Credential Schema is part of the canonical registry architecture and must remain immutable."
  }
}
